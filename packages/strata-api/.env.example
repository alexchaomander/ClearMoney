# Strata API - Environment Configuration Example

# Core Settings
STRATA_APP_NAME="Strata API (Sandbox)"
STRATA_DEBUG=true
STRATA_DATABASE_URL="sqlite+aiosqlite:///./strata.db"
STRATA_CORS_ALLOW_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# Advisor (LLM) Configuration
# advisor_provider: 'anthropic' or 'openrouter'
STRATA_ADVISOR_PROVIDER="openrouter"
STRATA_ADVISOR_MODEL="anthropic/claude-3.5-sonnet"
STRATA_ADVISOR_BASE_URL="https://openrouter.ai/api/v1"
STRATA_ANTHROPIC_API_KEY="your-key-here"
STRATA_OPENAI_API_KEY="your-openrouter-key-here"

# Internal Brokerage Service
STRATA_BROKERAGE_SERVICE_URL="http://localhost:8010"
STRATA_BROKERAGE_INTERNAL_TOKEN="dev-brokerage-token"

# Plaid Configuration (Banking Aggregation)
STRATA_PLAID_CLIENT_ID="your-client-id"
STRATA_PLAID_SECRET="your-secret"
STRATA_PLAID_ENVIRONMENT="sandbox"

# Financial Data Providers (DIY)
STRATA_ALPHA_VANTAGE_API_KEY="your-key-here"
STRATA_ALCHEMY_API_KEY="your-key-here"

# Auth (Clerk)
STRATA_CLERK_SECRET_KEY="sk_test_..."
STRATA_CLERK_PEM_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Security
STRATA_CREDENTIALS_ENCRYPTION_KEY="generate-a-32-byte-base64-key"
